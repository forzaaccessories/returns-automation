# --- Shopify ---
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-07

# --- BobGo ---
BOBGO_BASE_URL=https://api.bobgo.co.za/v2
BOBGO_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Your warehouse address (collection destination for returns)
WAREHOUSE_NAME=Your Company Warehouse
WAREHOUSE_ADDRESS_1=123 Warehouse Street
WAREHOUSE_ADDRESS_2=
WAREHOUSE_CITY=Cape Town
WAREHOUSE_ZONE=Western Cape
WAREHOUSE_ZIP=8000
WAREHOUSE_COUNTRY=ZA
WAREHOUSE_PHONE=0210000000
WAREHOUSE_EMAIL=warehouse@yourcompany.co.za

# --- Unleashed ---
UNLEASHED_BASE_URL=https://api.unleashedsoftware.com
UNLEASHED_API_ID=xxxxxxxxxxxxxxxxxxxx
UNLEASHED_API_KEY=xxxxxxxxxxxxxxxxxxxx
UNLEASHED_WAREHOUSE_CODE=MAIN

# --- Email (for sending the waybill to the customer) ---
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Your Store Returns" <returns@yourcompany.co.za>

PORT=3000
RENDER_APP_URL=https://your-app.onrender.com/webhooks/returns-request
